<%- include('partials/header', { title: 'AI Recipe Generator' }) %>

<div class="container section">
  <div class="text-center mb-4">
    <h1 style="font-size:2.5rem; color:var(--green-dark);">✨ AI Recipe Generator</h1>
    <p style="font-size:1.15rem; color:var(--gray-600); max-width:550px; margin:0.75rem auto 0;">Describe what you're craving and Claude AI will create a personalized, nutritionist-approved recipe just for you.</p>
  </div>

  <div class="generator-layout">
    <div class="generator-form-card">
      <h2 style="margin-bottom:1.5rem; color:var(--green-dark);">Customize Your Recipe</h2>
      <form id="generatorForm">
        <div class="form-group">
          <label class="form-label" for="prompt">What would you like to eat? *</label>
          <textarea class="form-control" id="prompt" name="prompt" rows="3" placeholder="e.g. High protein breakfast with eggs and avocado, or a creamy pasta that's low carb..." required></textarea>
        </div>
        <div class="form-group">
          <label class="form-label" for="category">Category</label>
          <select class="form-control" id="category" name="category">
            <option value="">Any category</option>
            <% categories.forEach(cat => { %>
              <option value="<%= cat.name %>"><%= cat.icon %> <%= cat.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label" for="servings">Servings</label>
          <select class="form-control" id="servings" name="servings">
            <option value="1">1 serving</option>
            <option value="2">2 servings</option>
            <option value="4" selected>4 servings</option>
            <option value="6">6 servings</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Dietary Preferences</label>
          <div class="form-check">
            <% ['Vegan', 'Vegetarian', 'Gluten-Free', 'Dairy-Free', 'Keto', 'Paleo', 'Low-Carb', 'High-Protein'].forEach(d => { %>
              <label class="form-check-item">
                <input type="checkbox" name="dietary" value="<%= d %>">
                <%= d %>
              </label>
            <% }) %>
          </div>
        </div>
        <button type="submit" class="btn btn-orange btn-lg" style="width:100%; justify-content:center;" id="generateBtn">
          ✨ Generate Recipe
        </button>
        <p style="text-align:center; font-size:0.8rem; color:var(--gray-600); margin-top:0.75rem;">Powered by Claude AI · Takes ~10 seconds</p>
      </form>
    </div>

    <div class="generator-result" id="resultArea">
      <div class="result-placeholder" id="placeholder">
        <div class="placeholder-icon">🍽️</div>
        <h3 style="margin-bottom:0.5rem; color:var(--gray-800);">Your recipe will appear here</h3>
        <p>Fill in the form and click Generate to create your personalized fat-switching recipe.</p>
      </div>
      <div id="resultContent" style="display:none;"></div>
      <div id="errorArea" style="display:none;"></div>
    </div>
  </div>
</div>

<script>
const form = document.getElementById('generatorForm');
const btn = document.getElementById('generateBtn');
const placeholder = document.getElementById('placeholder');
const resultContent = document.getElementById('resultContent');
const errorArea = document.getElementById('errorArea');

let currentRecipe = null;

if (form) form.addEventListener('submit', async (e) => {
  e.preventDefault();
  const formData = new FormData(form);
  const dietary = [...document.querySelectorAll('input[name="dietary"]:checked')].map(el => el.value);
  const adminKey = new URLSearchParams(window.location.search).get('admin') || '';

  btn.disabled = true;
  btn.innerHTML = '<span class="spinner"></span> Generating...';
  placeholder.style.display = 'none';
  resultContent.style.display = 'none';
  errorArea.style.display = 'none';

  try {
    const res = await fetch('/api/generate-recipe', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        prompt: formData.get('prompt'),
        category: formData.get('category'),
        servings: formData.get('servings'),
        dietary,
        adminKey,
      }),
    });
    const data = await res.json();

    if (!res.ok || !data.success) throw new Error(data.error || 'Generation failed');

    const r = data.recipe;
    currentRecipe = r;
    const isAdmin = !!r.slug;
    const totalTime = (r.prep_time || 0) + (r.cook_time || 0);

    const adSlot = '<div class="ad-slot" style="margin:2rem 0;padding:1rem;background:#f5f5f5;text-align:center;border-radius:8px;"><span style="font-size:0.75rem;color:#999;">Advertisement</span><br><ins class="adsbygoogle" style="display:block" data-ad-format="auto" data-ad-client="ca-pub-9979915931813060"></ins></div>';

    const ingredientsHtml = `<ul style="list-style:none; margin-bottom:1.5rem;">
      ${r.ingredients.map(i => `<li style="padding:0.4rem 0; border-bottom:1px solid var(--gray-100);">✓ ${i}</li>`).join('')}
    </ul>`;

    const instructionItems = r.instructions.map(s => `<li style="padding:0.4rem 0;">${s}</li>`);
    const instructionsHtml = r.instructions.length > 3
      ? `<ol style="padding-left:1.25rem; margin-bottom:1rem;">${instructionItems.slice(0, 3).join('')}</ol>${adSlot}<ol style="padding-left:1.25rem; margin-bottom:1.5rem;" start="4">${instructionItems.slice(3).join('')}</ol>`
      : `<ol style="padding-left:1.25rem; margin-bottom:1.5rem;">${instructionItems.join('')}</ol>`;

    const ctaHtml = isAdmin
      ? `<div style="display:flex; gap:0.75rem; flex-wrap:wrap;">
          <a href="/recipe/${r.slug}" class="btn btn-primary">View Full Recipe →</a>
          <button onclick="downloadPDF(currentRecipe)" class="btn btn-orange">⬇ Download PDF</button>
        </div>`
      : `<button onclick="downloadPDF(currentRecipe)" class="btn btn-orange">⬇ Download PDF</button>`;

    resultContent.innerHTML = `
      <div class="alert alert-success">${isAdmin ? '✅ Recipe generated and saved!' : '✅ Recipe generated!'}</div>
      <h2 style="margin-bottom:0.5rem; color:var(--green-dark);">${r.title}</h2>
      <p style="color:var(--gray-600); margin-bottom:1rem;">${r.description}</p>
      <div style="display:flex; gap:1rem; flex-wrap:wrap; margin-bottom:1.5rem;">
        ${totalTime ? `<span>⏱ ${totalTime} min</span>` : ''}
        ${r.calories ? `<span>🔥 ${r.calories} cal</span>` : ''}
        ${r.protein ? `<span>💪 ${r.protein}g protein</span>` : ''}
        ${r.carbs ? `<span>🌾 ${r.carbs}g carbs</span>` : ''}
        ${r.fat ? `<span>🥑 ${r.fat}g fat</span>` : ''}
      </div>
      ${adSlot}
      <h3 style="margin-bottom:0.75rem; color:var(--green-dark);">🛒 Ingredients</h3>
      ${ingredientsHtml}
      <h3 style="margin-bottom:0.75rem; color:var(--green-dark);">👨‍🍳 Instructions</h3>
      ${instructionsHtml}
      <div style="margin-top:1rem;">
        ${ctaHtml}
      </div>
      ${adSlot}
    `;
    resultContent.style.display = 'block';
  } catch (err) {
    errorArea.innerHTML = `<div class="alert alert-error">❌ ${err.message}</div>`;
    errorArea.style.display = 'block';
    placeholder.style.display = 'block';
  } finally {
    btn.disabled = false;
    btn.innerHTML = '✨ Generate Recipe';
  }
});

function downloadPDF(r) {
  if (!r) return;
  const win = window.open('', '_blank');
  if (!win) { alert('Please allow pop-ups to download the PDF.'); return; }
  const esc = s => String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  const nutItem = (label, val, unit) => val ? `<div class="ni"><span class="nv">${esc(val)}${unit}</span><span class="nl">${label}</span></div>` : '';
  win.document.write(`<!DOCTYPE html>
<html><head><meta charset="utf-8"><title>${esc(r.title)}</title>
<style>
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:Georgia,serif;max-width:700px;margin:0 auto;padding:2rem;color:#1a1a1a}
  h1{font-size:1.9rem;color:#2d6a4f;margin-bottom:.5rem}
  .desc{color:#555;font-size:.95rem;line-height:1.6;margin-bottom:1rem}
  .meta{display:flex;gap:1.5rem;flex-wrap:wrap;margin-bottom:1.5rem;font-size:.85rem;color:#555;border-bottom:2px solid #e8f5e9;padding-bottom:1rem}
  .meta b{font-weight:600}
  img.hero{width:100%;max-height:280px;object-fit:cover;border-radius:8px;margin-bottom:1.5rem}
  h2{font-size:.95rem;font-weight:700;color:#2d6a4f;margin:1.5rem 0 .75rem;text-transform:uppercase;letter-spacing:.05em}
  ul.ing{list-style:none}
  ul.ing li{padding:.35rem 0;border-bottom:1px solid #f0f0f0;font-size:.9rem}
  ul.ing li::before{content:"✓  ";color:#2d6a4f;font-weight:bold}
  ol.ins{padding-left:1.5rem}
  ol.ins li{padding:.4rem 0;font-size:.9rem;line-height:1.5;border-bottom:1px solid #f0f0f0}
  .nut{display:flex;gap:1.5rem;flex-wrap:wrap;background:#f0f7f0;padding:1rem 1.5rem;border-radius:8px;margin-top:.5rem}
  .ni{text-align:center;min-width:55px}
  .nv{font-size:1.1rem;font-weight:700;color:#2d6a4f;display:block}
  .nl{font-size:.7rem;color:#888;text-transform:uppercase}
  .foot{margin-top:2rem;font-size:.75rem;color:#aaa;text-align:center;border-top:1px solid #eee;padding-top:1rem}
  @media print{@page{margin:1.5cm}}
</style></head><body>
${r.image_url ? `<img class="hero" src="${esc(r.image_url)}" alt="${esc(r.title)}">` : ''}
<h1>${esc(r.title)}</h1>
${r.description ? `<p class="desc">${esc(r.description)}</p>` : ''}
<div class="meta">
  ${(r.prep_time||r.cook_time) ? `<b>⏱ ${(r.prep_time||0)+(r.cook_time||0)} min</b>` : ''}
  ${r.servings ? `<b>👥 ${r.servings} servings</b>` : ''}
  ${r.calories ? `<b>🔥 ${r.calories} cal</b>` : ''}
  ${r.protein ? `<b>💪 ${r.protein}g protein</b>` : ''}
</div>
<h2>Ingredients</h2>
<ul class="ing">${(r.ingredients||[]).map(i=>`<li>${esc(i)}</li>`).join('')}</ul>
<h2>Instructions</h2>
<ol class="ins">${(r.instructions||[]).map(s=>`<li>${esc(s)}</li>`).join('')}</ol>
${(r.calories||r.protein||r.carbs||r.fat||r.fiber)?`<h2>Nutrition per Serving</h2><div class="nut">${nutItem('Calories',r.calories,'')}${nutItem('Protein',r.protein,'g')}${nutItem('Carbs',r.carbs,'g')}${nutItem('Fat',r.fat,'g')}${nutItem('Fiber',r.fiber,'g')}</div>`:''}
<div class="foot">FatSwitchDiet.com</div>
<script>window.onload=function(){window.print()}<\/script>
</body></html>`);
  win.document.close();
}
</script>

<%- include('partials/footer') %>
