<%
  pageTitle    = 'AI Recipe Generator — FatSwitchDiet';
  metaDesc     = 'Generate any recipe instantly with the Fat Switch — our AI creates a full recipe with calorie comparison and healthy swaps in seconds.';
  canonicalUrl = '/generator';
%>
<%- include('partials/header') %>

<style>
.gen-hero {
  background: var(--forest);
  padding: 60px 24px 80px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.gen-hero::before {
  content: '⚡';
  position: absolute;
  font-size: 18rem;
  opacity: 0.04;
  top: -40px;
  left: 50%;
  transform: translateX(-50%);
  line-height: 1;
}
.gen-card {
  background: var(--white);
  border-radius: var(--radius-lg);
  padding: 40px;
  max-width: 680px;
  margin: -40px auto 0;
  position: relative;
  box-shadow: 0 20px 60px rgba(0,0,0,0.15);
  border: 1px solid var(--border);
}
.gen-input-main {
  width: 100%;
  border: 2.5px solid var(--border);
  border-radius: var(--radius);
  padding: 16px 20px;
  font-family: var(--font-body);
  font-size: 1.1rem;
  color: var(--text);
  outline: none;
  transition: border-color 0.2s;
  margin-bottom: 16px;
}
.gen-input-main:focus { border-color: var(--forest); }
.gen-options {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  margin-bottom: 20px;
}
.gen-select {
  width: 100%;
  border: 1.5px solid var(--border);
  border-radius: var(--radius);
  padding: 10px 14px;
  font-family: var(--font-ui);
  font-size: 0.88rem;
  color: var(--text);
  background: var(--white);
  outline: none;
  cursor: pointer;
}
.gen-select:focus { border-color: var(--forest); }
.gen-btn {
  width: 100%;
  background: var(--forest);
  color: var(--cream);
  border: none;
  border-radius: var(--radius);
  padding: 16px;
  font-family: var(--font-ui);
  font-size: 1rem;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.25s;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
}
.gen-btn:hover:not(:disabled) {
  background: var(--amber);
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(30,58,47,0.25);
}
.gen-btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

/* Admin badge */
.admin-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: #1a1a2e;
  color: #ffd700;
  font-family: var(--font-ui);
  font-size: 0.75rem;
  font-weight: 700;
  padding: 4px 12px;
  border-radius: 20px;
  margin-bottom: 16px;
  letter-spacing: 0.05em;
}

/* Loading state */
.gen-loading {
  display: none;
  text-align: center;
  padding: 40px 20px;
}
.gen-loading-spinner {
  width: 48px;
  height: 48px;
  border: 4px solid var(--border);
  border-top-color: var(--forest);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin: 0 auto 16px;
}
@keyframes spin { to { transform: rotate(360deg); } }
.gen-loading-steps {
  list-style: none;
  font-family: var(--font-ui);
  font-size: 0.88rem;
  color: var(--text-light);
  margin-top: 12px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.gen-loading-steps li { transition: color 0.3s; }
.gen-loading-steps li.active { color: var(--forest); font-weight: 600; }
.gen-loading-steps li.done { color: var(--amber); }
.gen-loading-steps li.done::before { content: '✓ '; }

/* Error */
.gen-error {
  display: none;
  background: #FFF5F5;
  border: 1px solid #FED7D7;
  border-radius: var(--radius);
  padding: 14px 18px;
  color: #C53030;
  font-family: var(--font-ui);
  font-size: 0.88rem;
  margin-top: 12px;
}

/* Public result preview card */
.gen-result {
  display: none;
}
.gen-result-header {
  background: linear-gradient(135deg, var(--forest), #2d6a4f);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  padding: 24px;
  color: var(--cream);
  margin: -40px -40px 24px;
}
.fat-switch-bar {
  display: flex;
  gap: 12px;
  margin-top: 16px;
}
.kcal-box {
  flex: 1;
  background: rgba(255,255,255,0.12);
  border-radius: var(--radius);
  padding: 12px;
  text-align: center;
}
.kcal-box .num { font-size: 1.6rem; font-weight: 800; line-height: 1; }
.kcal-box .lbl { font-size: 0.72rem; opacity: 0.8; margin-top: 2px; }
.kcal-box.savings { background: var(--amber); color: var(--forest); }
.swap-list { list-style: none; margin: 0 0 20px; }
.swap-list li {
  display: flex;
  gap: 10px;
  padding: 10px 0;
  border-bottom: 1px solid var(--border);
  font-size: 0.88rem;
}
.swap-list li:last-child { border-bottom: none; }
.swap-arrow { color: var(--amber); font-weight: 700; flex-shrink: 0; }
.gen-result-btn {
  width: 100%;
  background: var(--forest);
  color: var(--cream);
  border: none;
  border-radius: var(--radius);
  padding: 14px;
  font-family: var(--font-ui);
  font-size: 0.95rem;
  font-weight: 700;
  cursor: pointer;
  margin-top: 8px;
}
.gen-result-btn:hover { background: var(--amber); color: var(--forest); }

/* Recent recipes mini list */
.recent-list { list-style: none; }
.recent-list li {
  padding: 10px 0;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  gap: 12px;
  font-size: 0.9rem;
}
.recent-list li:last-child { border-bottom: none; }
.recent-list a { color: var(--forest) !important; font-weight: 600; }
.recent-badge {
  font-family: var(--font-ui);
  font-size: 0.7rem;
  padding: 2px 8px;
  border-radius: 10px;
  background: var(--cream-dark);
  color: var(--text-mid);
  white-space: nowrap;
}
</style>

<!-- ══ GENERATOR HERO ══ -->
<div class="gen-hero">
  <p style="font-family:var(--font-ui);font-size:0.78rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--amber-light);margin-bottom:12px">AI-Powered ✦ FatSwitchDiet</p>
  <h1 style="color:var(--cream);font-size:clamp(1.8rem,5vw,3rem);margin-bottom:12px">Generate Any Recipe.<br>Instantly.</h1>
  <p style="color:rgba(250,247,240,0.7);font-size:1rem;max-width:480px;margin:0 auto">Type any dish — our AI creates a complete Fat Switch recipe with nutrition comparison, ingredient swaps, and smart calorie cuts.</p>
</div>

<div class="page-wrap">

  <!-- ══ GENERATOR CARD ══ -->
  <div class="gen-card">

    <!-- Form -->
    <div id="genForm">

      <% if (isAdmin) { %>
      <div class="admin-badge">🔑 Admin Mode — recipes will be saved to database</div>
      <% } %>

      <label style="display:block;font-family:var(--font-ui);font-size:0.82rem;font-weight:600;color:var(--text);margin-bottom:6px;letter-spacing:0.03em">
        RECIPE NAME OR KEYWORD *
      </label>
      <input
        type="text"
        id="genKeyword"
        class="gen-input-main"
        placeholder="e.g. Creamy Chicken Alfredo, Pad Thai, Chocolate Lava Cake…"
        maxlength="80"
        autocomplete="off"
      >

      <div class="gen-options">
        <div>
          <label style="display:block;font-family:var(--font-ui);font-size:0.78rem;font-weight:600;color:var(--text-light);margin-bottom:5px">CATEGORY (optional)</label>
          <select id="genCategory" class="gen-select">
            <option value="">Any category</option>
            <option>Breakfast</option>
            <option>Lunch</option>
            <option>Dinner</option>
            <option>Snack</option>
            <option>Dessert</option>
          </select>
        </div>
        <div>
          <label style="display:block;font-family:var(--font-ui);font-size:0.78rem;font-weight:600;color:var(--text-light);margin-bottom:5px">DIETARY NOTE (optional)</label>
          <select id="genDietary" class="gen-select">
            <option value="">None</option>
            <option>Low carb</option>
            <option>High protein</option>
            <option>Gluten-free</option>
            <option>Dairy-free</option>
            <option>Vegetarian</option>
            <option>Keto-friendly</option>
          </select>
        </div>
      </div>

      <button class="gen-btn" id="genBtn" onclick="generateRecipe()">
        <span>⚡</span> Generate Fat Switch Recipe
      </button>
      <div class="gen-error" id="genError"></div>

      <p style="text-align:center;font-family:var(--font-ui);font-size:0.75rem;color:var(--text-light);margin-top:14px">
        Takes ~10–15 seconds · Free to use
      </p>
    </div>

    <!-- Loading state -->
    <div class="gen-loading" id="genLoading">
      <div class="gen-loading-spinner"></div>
      <p style="font-family:var(--font-display);font-size:1.2rem;font-weight:700;color:var(--forest)" id="loadingTitle">Creating your recipe…</p>
      <ul class="gen-loading-steps" id="loadingSteps">
        <li id="step1" class="active">🧠 Analysing recipe and cuisine…</li>
        <li id="step2">🔄 Finding the best Fat Switch swaps…</li>
        <li id="step3">📊 Calculating nutrition comparison…</li>
        <li id="step4">📝 Writing instructions and tips…</li>
        <li id="step5" id="step5Admin"><%= isAdmin ? '💾 Saving to database…' : '✅ Finishing up…' %></li>
      </ul>
    </div>

    <!-- Public result preview (shown only in non-admin mode) -->
    <div class="gen-result" id="genResult">
      <div class="gen-result-header">
        <p style="font-size:0.78rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;opacity:0.7;margin-bottom:6px">Fat Switch Recipe</p>
        <h2 id="resultTitle" style="font-size:1.4rem;margin:0 0 16px"></h2>
        <div class="fat-switch-bar">
          <div class="kcal-box">
            <div class="num" id="resultOrigKcal">—</div>
            <div class="lbl">Original kcal</div>
          </div>
          <div class="kcal-box savings">
            <div class="num" id="resultSavings">—</div>
            <div class="lbl">You save</div>
          </div>
          <div class="kcal-box">
            <div class="num" id="resultNewKcal">—</div>
            <div class="lbl">Fat Switch kcal</div>
          </div>
        </div>
      </div>

      <p style="font-family:var(--font-ui);font-size:0.82rem;font-weight:600;color:var(--text-light);margin-bottom:10px;letter-spacing:0.05em">THE SWAPS</p>
      <ul class="swap-list" id="resultSwaps"></ul>

      <p id="resultHeadline" style="font-style:italic;color:var(--text-mid);font-size:0.9rem;text-align:center;margin:16px 0"></p>

      <button class="gen-result-btn" onclick="resetGenerator()">⚡ Generate Another Recipe</button>
    </div>

  </div>

  <!-- ══ AD SLOT ══ -->
  <div class="ad-slot" style="max-width:680px;margin:32px auto">
    <span class="ad-slot-label">Advertisement</span>
    <span class="ad-slot-size">728×90</span>
  </div>

  <!-- ══ HOW IT WORKS ══ -->
  <div style="max-width:680px;margin:0 auto 48px">
    <h2 style="text-align:center;margin-bottom:32px">How It Works</h2>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;text-align:center">
      <div style="padding:20px">
        <div style="font-size:2.5rem;margin-bottom:10px">⌨️</div>
        <strong style="font-family:var(--font-ui);font-size:0.88rem;color:var(--forest)">1. Type a dish name</strong>
        <p style="font-size:0.85rem;color:var(--text-mid);margin-top:6px">Any recipe, any cuisine — our AI knows them all.</p>
      </div>
      <div style="padding:20px">
        <div style="font-size:2.5rem;margin-bottom:10px">⚡</div>
        <strong style="font-family:var(--font-ui);font-size:0.88rem;color:var(--forest)">2. AI generates everything</strong>
        <p style="font-size:0.85rem;color:var(--text-mid);margin-top:6px">Full recipe + Fat Switch swaps + nutrition in ~15 seconds.</p>
      </div>
      <div style="padding:20px">
        <div style="font-size:2.5rem;margin-bottom:10px">🔄</div>
        <strong style="font-family:var(--font-ui);font-size:0.88rem;color:var(--forest)">3. See your Fat Switch</strong>
        <p style="font-size:0.85rem;color:var(--text-mid);margin-top:6px">Instant calorie comparison and smart ingredient swaps revealed.</p>
      </div>
    </div>
  </div>

  <!-- ══ RECENTLY GENERATED ══ -->
  <div style="max-width:680px;margin:0 auto 60px">
    <h2 style="margin-bottom:16px">Recently Added Recipes</h2>
    <div id="recentRecipes" style="background:var(--white);border-radius:var(--radius-lg);border:1px solid var(--border);padding:8px 20px">
      <p style="color:var(--text-light);font-size:0.9rem;text-align:center;padding:20px 0">Loading recent recipes…</p>
    </div>
  </div>

</div>

<script>
// ── Admin mode flag from server ──
const IS_ADMIN = <%= isAdmin ? 'true' : 'false' %>;
const ADMIN_KEY = IS_ADMIN ? 'fatswitchdev2026' : null;

// ── Load recent recipes on page load ──
(async function loadRecent() {
  try {
    const res  = await fetch('/api/recipes');
    const data = await res.json();
    const container = document.getElementById('recentRecipes');
    if (!data.length) {
      container.innerHTML = '<p style="color:var(--text-light);font-size:0.9rem;text-align:center;padding:20px 0">No recipes yet — generate the first one!</p>';
      return;
    }
    container.innerHTML = `<ul class="recent-list">
      ${data.slice(0, 8).map(r => `
        <li>
          <span style="font-size:1.2rem">${getCuisineEmoji(r.cuisine)}</span>
          <a href="/recipe/${r.slug}">${r.title}</a>
          <span class="recent-badge">${r.category}</span>
          ${r.savings_pct ? `<span class="recent-badge" style="background:#EBF5ED;color:#155724">↓${r.savings_pct}% kcal</span>` : ''}
        </li>
      `).join('')}
    </ul>`;
  } catch(e) {
    console.error(e);
  }
})();

function getCuisineEmoji(cuisine) {
  const map = { Japanese:'🍱', Korean:'🥢', Thai:'🍜', Italian:'🍝', Chinese:'🥟', Indian:'🍛', Mexican:'🌮', French:'🥐', American:'🍔', Mediterranean:'🫒' };
  return map[cuisine] || '🍽️';
}

// ── Generate Recipe ──
async function generateRecipe() {
  const keyword = document.getElementById('genKeyword').value.trim();
  const category = document.getElementById('genCategory').value;
  const dietary = document.getElementById('genDietary').value;
  const errEl   = document.getElementById('genError');

  errEl.style.display = 'none';

  if (!keyword) {
    errEl.textContent = '⚠️ Please enter a recipe name or keyword.';
    errEl.style.display = 'block';
    document.getElementById('genKeyword').focus();
    return;
  }

  // Show loading
  document.getElementById('genForm').style.display    = 'none';
  document.getElementById('genLoading').style.display = 'block';

  // Animate loading steps
  const steps    = ['step1','step2','step3','step4','step5'];
  let stepIndex  = 0;
  const stepInterval = setInterval(() => {
    if (stepIndex > 0) document.getElementById(steps[stepIndex - 1]).classList.replace('active', 'done');
    if (stepIndex < steps.length) {
      document.getElementById(steps[stepIndex]).classList.add('active');
      stepIndex++;
    }
  }, 2500);

  try {
    // FIX: Include adminKey in request body if in admin mode
    const payload = { keyword, category, dietary };
    if (IS_ADMIN) payload.adminKey = ADMIN_KEY;

    const res  = await fetch('/api/generate', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify(payload)
    });
    const data = await res.json();

    clearInterval(stepInterval);

    if (!res.ok || !data.success) {
      showError(data.error || 'Generation failed. Please try again.');
      return;
    }

    // Mark all steps done
    steps.forEach(s => {
      const el = document.getElementById(s);
      el.classList.remove('active');
      el.classList.add('done');
    });

    document.getElementById('loadingTitle').textContent = '✅ Recipe ready!';

    if (IS_ADMIN && data.savedToDB && data.slug) {
      // FIX: Admin mode — redirect to the saved recipe page
      setTimeout(() => {
        window.location.href = '/recipe/' + data.slug;
      }, 800);
    } else {
      // FIX: Public mode — show inline result card
      setTimeout(() => {
        showPublicResult(data);
      }, 600);
    }

  } catch (err) {
    clearInterval(stepInterval);
    showError('Network error. Please check your connection and try again.');
  }
}

// ── Show inline result for public mode ──
function showPublicResult(data) {
  document.getElementById('genLoading').style.display = 'none';

  const recipe = data.data;
  const fs     = recipe.fat_switch;

  document.getElementById('resultTitle').textContent     = recipe.title;
  document.getElementById('resultOrigKcal').textContent  = fs.original_kcal;
  document.getElementById('resultNewKcal').textContent   = fs.switched_kcal;
  document.getElementById('resultSavings').textContent   = '−' + fs.savings_kcal + ' kcal';
  document.getElementById('resultHeadline').textContent  = fs.headline;

  const swapsList = document.getElementById('resultSwaps');
  swapsList.innerHTML = (fs.swaps || []).map(s => `
    <li>
      <span>🔴 ${s.original}</span>
      <span class="swap-arrow">→</span>
      <span>🟢 ${s.switched} <span style="color:var(--text-light);font-size:0.82rem">— ${s.reason}</span></span>
    </li>
  `).join('');

  document.getElementById('genResult').style.display = 'block';
}

// ── Reset back to form ──
function resetGenerator() {
  document.getElementById('genResult').style.display  = 'none';
  document.getElementById('genForm').style.display    = 'block';
  document.getElementById('genKeyword').value         = '';
  document.getElementById('genError').style.display   = 'none';

  // Reset loading steps
  ['step1','step2','step3','step4','step5'].forEach(s => {
    const el = document.getElementById(s);
    el.classList.remove('active', 'done');
  });
  document.getElementById('step1').classList.add('active');
  document.getElementById('loadingTitle').textContent = 'Creating your recipe…';
}

function showError(msg) {
  document.getElementById('genLoading').style.display = 'none';
  document.getElementById('genForm').style.display    = 'block';
  const errEl = document.getElementById('genError');
  errEl.textContent  = '⚠️ ' + msg;
  errEl.style.display = 'block';
}

// Enter key trigger
document.getElementById('genKeyword').addEventListener('keydown', e => {
  if (e.key === 'Enter') generateRecipe();
});
</script>

<%- include('partials/footer') %>
