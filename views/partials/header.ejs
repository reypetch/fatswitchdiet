<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="FatSwitchDiet – Science-based recipes and meal plans to optimize fat-burning and metabolic health.">
  <title><%= typeof title !== 'undefined' ? title + ' | FatSwitchDiet' : 'FatSwitchDiet – Recipes for Metabolic Health' %></title>
  <link rel="stylesheet" href="/style.css">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🥗</text></svg>">
</head>
<body>
  <nav class="navbar">
    <div class="container navbar-inner">
      <a href="/" class="navbar-brand">🥗 Fat<span>Switch</span>Diet</a>
      <ul class="navbar-nav">
        <li><a href="/" class="<%= page === 'home' ? 'active' : '' %>">Home</a></li>
        <% if (typeof categories !== 'undefined') { %>
          <% categories.slice(0, 3).forEach(cat => { %>
            <li><a href="/category/<%= cat.slug %>"><%= cat.name %></a></li>
          <% }) %>
        <% } %>
        <li><a href="/diet-plan" class="<%= page === 'diet-plan' ? 'active' : '' %>">Diet Plans</a></li>
        <li><a href="/generator" class="btn-nav <%= page === 'generator' ? 'active' : '' %>">✨ AI Generator</a></li>
      </ul>
    </div>
  </nav>
