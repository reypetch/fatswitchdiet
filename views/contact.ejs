<% pageTitle = 'Contact — FatSwitchDiet'; canonicalUrl = '/contact'; %>
<%- include('partials/header') %>
<div class="static-hero"><h1>Get In Touch</h1><p>We'd love to hear from you</p></div>
<div class="static-content">
  <h2 style="margin-top:0">Send a Message</h2>
  <div class="contact-form">
    <div class="form-group"><label>Your Name</label><input type="text" id="cName" placeholder="Alex Smith"></div>
    <div class="form-group"><label>Email Address</label><input type="email" id="cEmail" placeholder="hello@example.com"></div>
    <div class="form-group"><label>Subject</label>
      <select id="cSubject" class="form-group input" style="width:100%;border:1.5px solid var(--border);border-radius:var(--radius);padding:12px 16px;font-family:var(--font-body);font-size:1rem;outline:none">
        <option>Recipe Request</option>
        <option>Question about a Recipe</option>
        <option>Partnership / Collaboration</option>
        <option>Advertising Enquiry</option>
        <option>Other</option>
      </select>
    </div>
    <div class="form-group"><label>Message</label><textarea id="cMsg" placeholder="Tell us what's on your mind…"></textarea></div>
    <button class="btn btn-primary" onclick="submitMsg()" style="width:100%;justify-content:center">Send Message →</button>
    <div id="cSuccess" style="display:none;margin-top:16px;background:#EBF5ED;border-radius:var(--radius);padding:14px;text-align:center;color:#155724;font-family:var(--font-ui);font-size:0.9rem">✅ Message sent! We'll reply within 48 hours.</div>
  </div>
</div>
<script>
function submitMsg() {
  if (!document.getElementById('cName').value || !document.getElementById('cEmail').value) { alert('Please fill in name and email.'); return; }
  document.getElementById('cSuccess').style.display = 'block';
  ['cName','cEmail','cMsg'].forEach(id => document.getElementById(id).value = '');
}
</script>
<%- include('partials/footer') %>
