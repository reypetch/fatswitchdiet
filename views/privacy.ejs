<%- include('partials/header', { title: 'Privacy Policy' }) %>

<div class="container section">
  <div style="max-width:800px; margin:0 auto;">
    <h1 style="margin-bottom:0.5rem; color:var(--green-dark);">Privacy Policy</h1>
    <p style="color:var(--gray-600); margin-bottom:2.5rem;">Last updated: <%= new Date().toLocaleDateString('en-US', {year:'numeric', month:'long', day:'numeric'}) %></p>

    <% [
      { title: '1. Information We Collect', body: 'We collect information you provide when using our AI generator features, including recipe prompts and dietary preferences. We do not collect personally identifiable information unless you voluntarily provide it via our contact form.' },
      { title: '2. How We Use Information', body: 'Recipe prompts are processed by the Anthropic Claude API to generate recipe content. We store generated recipes in our database to improve the site experience. We do not sell or share your data with third parties for marketing purposes.' },
      { title: '3. AI-Generated Content', body: 'Recipe and diet plan generation uses Anthropic\'s Claude AI. Your prompts are sent to Anthropic\'s API for processing. Please review Anthropic\'s privacy policy for details on how they handle API data.' },
      { title: '4. Cookies', body: 'We use essential cookies only to maintain site functionality. We do not use tracking or advertising cookies. You can disable cookies in your browser settings without affecting core site functionality.' },
      { title: '5. Data Security', body: 'We implement reasonable security measures to protect your information. However, no internet transmission is 100% secure. Do not share sensitive personal health information in recipe prompts.' },
      { title: '6. Medical Disclaimer', body: 'Content on FatSwitchDiet is for informational purposes only and does not constitute medical advice. Always consult a qualified healthcare professional before making significant dietary changes.' },
      { title: '7. Contact', body: 'For privacy-related questions, please use our contact form.' },
    ].forEach(section => { %>
      <div style="background:var(--white); border-radius:var(--radius); box-shadow:var(--shadow); padding:1.75rem; margin-bottom:1.25rem;">
        <h2 style="font-size:1.15rem; color:var(--green-dark); margin-bottom:0.75rem;"><%= section.title %></h2>
        <p style="color:var(--gray-800); line-height:1.8;"><%= section.body %></p>
      </div>
    <% }) %>
  </div>
</div>

<%- include('partials/footer') %>
