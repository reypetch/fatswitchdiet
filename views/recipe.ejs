<%- include('partials/header', { title: recipe.title }) %>

<div class="container" style="padding-top:2.5rem; padding-bottom:3rem;">
  <nav style="font-size:0.9rem; color:var(--gray-600); margin-bottom:2rem;">
    <a href="/" style="color:var(--green);">Home</a> &rsaquo;
    <% if (recipe.category_name) { %>
      <a href="/category/<%= recipe.category_slug %>" style="color:var(--green);"><%= recipe.category_name %></a> &rsaquo;
    <% } %>
    <%= recipe.title %>
  </nav>

  <div class="recipe-layout">
    <div>
      <% if (recipe.image_url) { %>
        <img src="<%= recipe.image_url %>" alt="<%= recipe.title %>" style="width:100%;height:400px;object-fit:cover;border-radius:12px;">
      <% } else { %>
        <div class="recipe-hero-img">🍽️</div>
      <% } %>

      <div style="margin:1.5rem 0;">
        <div style="display:flex; gap:0.5rem; flex-wrap:wrap; margin-bottom:1rem;">
          <% if (recipe.category_name) { %><span class="card-category"><%= recipe.category_name %></span><% } %>
          <% if (recipe.ai_generated) { %><span class="ai-badge">🤖 AI Generated</span><% } %>
        </div>
        <h1 style="font-size:2.2rem; margin-bottom:0.75rem;"><%= recipe.title %></h1>
        <p style="font-size:1.1rem; color:var(--gray-600); line-height:1.7;"><%= recipe.description %></p>
      </div>

      <div class="recipe-meta-bar">
        <% if (recipe.prep_time) { %>
          <div class="recipe-meta-item"><div class="value"><%= recipe.prep_time %>m</div><div class="label">Prep Time</div></div>
        <% } %>
        <% if (recipe.cook_time) { %>
          <div class="recipe-meta-item"><div class="value"><%= recipe.cook_time %>m</div><div class="label">Cook Time</div></div>
        <% } %>
        <div class="recipe-meta-item"><div class="value"><%= recipe.servings || 4 %></div><div class="label">Servings</div></div>
        <% if (recipe.calories) { %>
          <div class="recipe-meta-item"><div class="value"><%= recipe.calories %></div><div class="label">Calories</div></div>
        <% } %>
        <% if (recipe.protein) { %>
          <div class="recipe-meta-item"><div class="value"><%= recipe.protein %>g</div><div class="label">Protein</div></div>
        <% } %>
      </div>

      <!-- AdSense Slot 1 - Below Description -->
      <div class="ad-slot" style="margin:2rem 0;padding:1rem;background:#f5f5f5;text-align:center;border-radius:8px;">
        <span style="font-size:0.75rem;color:#999;">Advertisement</span><br>
        <!-- Replace with real AdSense code when approved -->
        <ins class="adsbygoogle" style="display:block" data-ad-format="auto"></ins>
      </div>

      <div style="background:var(--white); border-radius:var(--radius); box-shadow:var(--shadow); padding:2rem; margin-bottom:1.5rem;">
        <h2 style="margin-bottom:1rem; color:var(--green-dark);">🛒 Ingredients</h2>
        <ul class="ingredients-list" style="list-style:none;">
          <% recipe.ingredients.forEach(ing => { %>
            <li style="display:flex; align-items:flex-start; gap:0.5rem; padding:0.6rem 0; border-bottom:1px solid var(--gray-100);">
              <span style="color:var(--green); flex-shrink:0;">✓</span>
              <%= ing %>
            </li>
          <% }) %>
        </ul>
      </div>

      <div style="background:var(--white); border-radius:var(--radius); box-shadow:var(--shadow); padding:2rem;">
        <h2 style="margin-bottom:1rem; color:var(--green-dark);">👨‍🍳 Instructions</h2>
        <% let stepNum = 0; %>
        <% recipe.instructions.forEach((step, i) => { stepNum++; %>
          <div style="display:flex; gap:0.75rem; padding:0.6rem 0; border-bottom:1px solid var(--gray-100);">
            <span style="font-weight:700; color:var(--green-dark); flex-shrink:0; min-width:1.4rem;"><%= stepNum %>.</span>
            <span><%= step %></span>
          </div>
          <% if (i === 2 && recipe.instructions.length > 3) { %>
            <div style="margin:1.5rem 0;padding:1rem;background:#f0f7f0;border:1px solid #c8e6c9;border-radius:8px;text-align:center;font-size:0.8rem;color:#666;">
              📢 Advertisement
            </div>
          <% } %>
        <% }) %>
        <div style="margin-top:1.5rem; padding-top:1rem; border-top:1px solid var(--gray-100);">
          <button onclick="downloadRecipePDF()" class="btn btn-orange">⬇ Download PDF</button>
        </div>
      </div>
    </div>

    <div>
      <% if (recipe.calories || recipe.protein || recipe.carbs || recipe.fat) { %>
      <div class="nutrition-card mb-3">
        <h3 style="margin-bottom:1rem; font-size:1.1rem;">📊 Nutrition per Serving</h3>
        <% if (recipe.calories) { %><div class="nutrition-row"><span>Calories</span><strong><%= recipe.calories %> kcal</strong></div><% } %>
        <% if (recipe.protein) { %><div class="nutrition-row"><span>Protein</span><strong><%= recipe.protein %>g</strong></div><% } %>
        <% if (recipe.carbs) { %><div class="nutrition-row"><span>Carbohydrates</span><strong><%= recipe.carbs %>g</strong></div><% } %>
        <% if (recipe.fat) { %><div class="nutrition-row"><span>Fat</span><strong><%= recipe.fat %>g</strong></div><% } %>
        <% if (recipe.fiber) { %><div class="nutrition-row"><span>Fiber</span><strong><%= recipe.fiber %>g</strong></div><% } %>
      </div>
      <% } %>

      <% if (recipe.tags && recipe.tags.length > 0) { %>
      <div style="background:var(--white); border-radius:var(--radius); box-shadow:var(--shadow); padding:1.5rem; margin-bottom:1.5rem;">
        <h3 style="margin-bottom:0.75rem; color:var(--green-dark);">🏷️ Tags</h3>
        <div class="tags">
          <% recipe.tags.forEach(tag => { %><span class="tag">#<%= tag %></span><% }) %>
        </div>
      </div>
      <% } %>

      <div style="background:var(--white); border-radius:var(--radius); box-shadow:var(--shadow); padding:1.5rem; text-align:center;">
        <div style="font-size:2.5rem; margin-bottom:0.75rem;">✨</div>
        <h3 style="margin-bottom:0.5rem;">Want more like this?</h3>
        <p style="color:var(--gray-600); font-size:0.9rem; margin-bottom:1rem;">Generate a custom recipe with AI</p>
        <a href="/generator" class="btn btn-primary" style="width:100%; justify-content:center;">AI Generator</a>
      </div>

      <!-- AdSense Sidebar 300x250 -->
      <div class="ad-slot" style="margin:1.5rem 0;padding:1rem;background:#f5f5f5;text-align:center;border-radius:8px;">
        <span style="font-size:0.75rem;color:#999;">Advertisement</span><br>
        <!-- Replace with real AdSense code when approved -->
        <ins class="adsbygoogle" style="display:block;width:300px;height:250px;margin:0 auto;" data-ad-format="rectangle"></ins>
      </div>
    </div>
  </div>

  <!-- AdSense Slot 2 - After Instructions -->
  <div class="ad-slot" style="margin:2rem 0;padding:1rem;background:#f5f5f5;text-align:center;border-radius:8px;">
    <span style="font-size:0.75rem;color:#999;">Advertisement</span><br>
    <!-- Replace with real AdSense code when approved -->
    <ins class="adsbygoogle" style="display:block" data-ad-format="auto"></ins>
  </div>

  <% if (related.length > 0) { %>
  <div style="margin-top:3rem;">
    <h2 style="margin-bottom:1.5rem; color:var(--green-dark);">You Might Also Like</h2>
    <div class="grid grid-3">
      <% related.forEach(r => { %>
        <div class="card">
          <% if (r.image_url) { %>
            <img src="<%= r.image_url %>" alt="<%= r.title %>" style="width:100%;height:180px;object-fit:cover;">
          <% } else { %>
            <div class="card-img-placeholder">🥗</div>
          <% } %>
          <div class="card-body">
            <h3 class="card-title"><a href="/recipe/<%= r.slug %>"><%= r.title %></a></h3>
            <p class="card-desc"><%= r.description %></p>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
  <% } %>
</div>

<script>
const recipeData = <%- JSON.stringify({
  title: recipe.title,
  description: recipe.description || '',
  image_url: recipe.image_url || null,
  prep_time: recipe.prep_time || null,
  cook_time: recipe.cook_time || null,
  servings: recipe.servings || null,
  calories: recipe.calories || null,
  protein: recipe.protein || null,
  carbs: recipe.carbs || null,
  fat: recipe.fat || null,
  fiber: recipe.fiber || null,
  ingredients: recipe.ingredients || [],
  instructions: recipe.instructions || []
}) %>;

function downloadRecipePDF() {
  const r = recipeData;
  const win = window.open('', '_blank');
  if (!win) { alert('Please allow pop-ups to download the PDF.'); return; }
  const esc = s => String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  const nutItem = (label, val, unit) => val ? `<div class="ni"><span class="nv">${esc(val)}${unit}</span><span class="nl">${label}</span></div>` : '';
  win.document.write(`<!DOCTYPE html>
<html><head><meta charset="utf-8"><title>${esc(r.title)}</title>
<style>
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:Georgia,serif;max-width:700px;margin:0 auto;padding:2rem;color:#1a1a1a}
  h1{font-size:1.9rem;color:#2d6a4f;margin-bottom:.5rem}
  .desc{color:#555;font-size:.95rem;line-height:1.6;margin-bottom:1rem}
  .meta{display:flex;gap:1.5rem;flex-wrap:wrap;margin-bottom:1.5rem;font-size:.85rem;color:#555;border-bottom:2px solid #e8f5e9;padding-bottom:1rem}
  .meta b{font-weight:600}
  img.hero{width:100%;max-height:280px;object-fit:cover;border-radius:8px;margin-bottom:1.5rem}
  h2{font-size:.95rem;font-weight:700;color:#2d6a4f;margin:1.5rem 0 .75rem;text-transform:uppercase;letter-spacing:.05em}
  ul.ing{list-style:none}
  ul.ing li{padding:.35rem 0;border-bottom:1px solid #f0f0f0;font-size:.9rem}
  ul.ing li::before{content:"✓  ";color:#2d6a4f;font-weight:bold}
  ol.ins{padding-left:1.5rem}
  ol.ins li{padding:.4rem 0;font-size:.9rem;line-height:1.5;border-bottom:1px solid #f0f0f0}
  .nut{display:flex;gap:1.5rem;flex-wrap:wrap;background:#f0f7f0;padding:1rem 1.5rem;border-radius:8px;margin-top:.5rem}
  .ni{text-align:center;min-width:55px}
  .nv{font-size:1.1rem;font-weight:700;color:#2d6a4f;display:block}
  .nl{font-size:.7rem;color:#888;text-transform:uppercase}
  .foot{margin-top:2rem;font-size:.75rem;color:#aaa;text-align:center;border-top:1px solid #eee;padding-top:1rem}
  @media print{@page{margin:1.5cm}}
</style></head><body>
${r.image_url ? `<img class="hero" src="${esc(r.image_url)}" alt="${esc(r.title)}">` : ''}
<h1>${esc(r.title)}</h1>
${r.description ? `<p class="desc">${esc(r.description)}</p>` : ''}
<div class="meta">
  ${(r.prep_time||r.cook_time) ? `<b>⏱ ${(r.prep_time||0)+(r.cook_time||0)} min</b>` : ''}
  ${r.servings ? `<b>👥 ${r.servings} servings</b>` : ''}
  ${r.calories ? `<b>🔥 ${r.calories} cal</b>` : ''}
  ${r.protein ? `<b>💪 ${r.protein}g protein</b>` : ''}
</div>
<h2>Ingredients</h2>
<ul class="ing">${(r.ingredients||[]).map(i=>`<li>${esc(i)}</li>`).join('')}</ul>
<h2>Instructions</h2>
<ol class="ins">${(r.instructions||[]).map(s=>`<li>${esc(s)}</li>`).join('')}</ol>
${(r.calories||r.protein||r.carbs||r.fat||r.fiber)?`<h2>Nutrition per Serving</h2><div class="nut">${nutItem('Calories',r.calories,'')}${nutItem('Protein',r.protein,'g')}${nutItem('Carbs',r.carbs,'g')}${nutItem('Fat',r.fat,'g')}${nutItem('Fiber',r.fiber,'g')}</div>`:''}
<div class="foot">FatSwitchDiet.com</div>
<script>window.onload=function(){window.print()}<\/script>
</body></html>`);
  win.document.close();
}
</script>

<%- include('partials/footer') %>
