<%- include('partials/header', { title: 'Healthy Recipes & Meal Plans' }) %>

<section class="hero">
  <div class="container">
    <h1>Switch Your Diet,<br>Switch Your Life</h1>
    <p>Science-backed recipes and AI-powered meal plans designed to optimize fat-burning and metabolic health.</p>
    <div class="hero-badges">
      <span class="badge">🔬 Science-Based</span>
      <span class="badge">🤖 AI-Powered</span>
      <span class="badge">🥗 500+ Recipes</span>
      <span class="badge">📋 Custom Diet Plans</span>
    </div>
    <div class="flex gap-2" style="justify-content:center; flex-wrap:wrap;">
      <a href="/generator" class="btn btn-outline btn-lg">✨ Generate a Recipe</a>
      <a href="/diet-plan" class="btn btn-lg" style="background:var(--orange);color:white;">📋 Get a Diet Plan</a>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <h2 class="section-title">Browse by Category</h2>
    <p class="section-subtitle">Find exactly what you're looking for</p>
    <div class="category-grid">
      <% categories.forEach(cat => { %>
        <a href="/category/<%= cat.slug %>" class="category-pill">
          <%= cat.icon %> <%= cat.name %>
        </a>
      <% }) %>
    </div>
  </div>
</section>

<% if (featured.length > 0) { %>
<section class="section" style="background: var(--white);">
  <div class="container">
    <h2 class="section-title">⭐ Featured Recipes</h2>
    <p class="section-subtitle">Hand-picked favorites for your fat-switching journey</p>
    <div class="grid grid-3">
      <% featured.forEach(recipe => { %>
        <div class="card">
          <div class="card-img-placeholder"><%= recipe.category_name === 'Smoothies' ? '🥤' : recipe.category_name === 'Breakfast' ? '🌅' : recipe.category_name === 'Desserts' ? '🍓' : '🥗' %></div>
          <div class="card-body">
            <% if (recipe.category_name) { %><span class="card-category"><%= recipe.category_name %></span><% } %>
            <h3 class="card-title"><a href="/recipe/<%= recipe.slug %>"><%= recipe.title %></a></h3>
            <p class="card-desc"><%= recipe.description %></p>
            <div class="card-meta">
              <% if (recipe.prep_time) { %><span>⏱ <%= recipe.prep_time + (recipe.cook_time || 0) %> min</span><% } %>
              <% if (recipe.calories) { %><span>🔥 <%= recipe.calories %> cal</span><% } %>
              <% if (recipe.protein) { %><span>💪 <%= recipe.protein %>g protein</span><% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<section class="section">
  <div class="container">
    <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap:2rem; text-align:center;">
      <div style="padding:2rem; background:white; border-radius:var(--radius); box-shadow:var(--shadow);">
        <div style="font-size:3rem;margin-bottom:1rem;">🤖</div>
        <h3 style="margin-bottom:0.5rem;">AI Recipe Generator</h3>
        <p style="color:var(--gray-600);margin-bottom:1.5rem;">Describe what you want and Claude AI creates a personalized, nutritionist-approved recipe in seconds.</p>
        <a href="/generator" class="btn btn-primary">Try It Free</a>
      </div>
      <div style="padding:2rem; background:white; border-radius:var(--radius); box-shadow:var(--shadow);">
        <div style="font-size:3rem;margin-bottom:1rem;">📋</div>
        <h3 style="margin-bottom:0.5rem;">7-Day Diet Plans</h3>
        <p style="color:var(--gray-600);margin-bottom:1.5rem;">Get a complete personalized meal plan tailored to your goals, preferences, and lifestyle.</p>
        <a href="/diet-plan" class="btn btn-primary">Get Your Plan</a>
      </div>
      <div style="padding:2rem; background:white; border-radius:var(--radius); box-shadow:var(--shadow);">
        <div style="font-size:3rem;margin-bottom:1rem;">🔬</div>
        <h3 style="margin-bottom:0.5rem;">Science-Based</h3>
        <p style="color:var(--gray-600);margin-bottom:1.5rem;">Every recipe is crafted around the Fat Switch principle — optimizing metabolic pathways for sustainable weight loss.</p>
        <a href="/about" class="btn btn-primary">Learn More</a>
      </div>
    </div>
  </div>
</section>

<% if (recent.length > 0) { %>
<section class="section" style="background: var(--white);">
  <div class="container">
    <h2 class="section-title">🆕 Latest Recipes</h2>
    <p class="section-subtitle">Fresh additions to the FatSwitchDiet collection</p>
    <div class="grid grid-4">
      <% recent.forEach(recipe => { %>
        <div class="card">
          <div class="card-img-placeholder" style="height:160px; font-size:3rem;">🥗</div>
          <div class="card-body">
            <% if (recipe.ai_generated) { %><span class="ai-badge mb-1">🤖 AI</span><% } %>
            <h3 class="card-title" style="font-size:1rem;"><a href="/recipe/<%= recipe.slug %>"><%= recipe.title %></a></h3>
            <div class="card-meta">
              <% if (recipe.calories) { %><span>🔥 <%= recipe.calories %></span><% } %>
              <% if (recipe.protein) { %><span>💪 <%= recipe.protein %>g</span><% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<section class="cta-section">
  <div class="container">
    <h2>Ready to Switch Your Diet?</h2>
    <p>Generate your first personalized recipe with AI — it takes less than 30 seconds.</p>
    <a href="/generator" class="btn btn-outline btn-lg">✨ Generate My First Recipe</a>
  </div>
</section>

<%- include('partials/footer') %>
