<% pageTitle = category + ' Recipes — FatSwitchDiet'; canonicalUrl = '/category/' + category.toLowerCase(); %>
<%- include('partials/header') %>
<div class="static-hero"><h1><%= category %> Recipes</h1><p><%= recipes.length %> Fat Switch recipe<%= recipes.length !== 1 ? 's' : '' %> found</p></div>
<div class="page-wrap" style="padding-top:40px;padding-bottom:80px">
  <% if (!recipes.length) { %>
  <div style="text-align:center;padding:60px 0">
    <div style="font-size:3rem;margin-bottom:16px">🍽️</div>
    <h2>No <%= category %> recipes yet</h2>
    <p style="color:var(--text-mid);margin-bottom:20px">Generate the first one!</p>
    <a href="/generator" class="btn btn-primary">⚡ Generate a Recipe →</a>
  </div>
  <% } else { %>
  <div class="recipe-grid">
    <% recipes.forEach(function(r) { %>
    <a href="/recipe/<%= r.slug %>" style="text-decoration:none">
      <div class="recipe-card">
        <div class="recipe-card-img-placeholder">🍽️</div>
        <div class="recipe-card-body">
          <div class="recipe-card-meta">
            <span class="tag tag-category"><%= r.category %></span>
            <% if (r.savings_pct) { %><span class="tag tag-swap">⚡ <%= r.savings_pct %>% less</span><% } %>
          </div>
          <div class="recipe-card-title"><%= r.title %></div>
          <div class="recipe-card-desc"><%= r.description ? r.description.substring(0,100)+'…' : '' %></div>
          <div class="recipe-card-stats">
            <% if (r.kcal) { %><span>✅ <%= r.kcal %> kcal</span><% } %>
            <span>👁 <%= r.views %></span>
          </div>
        </div>
      </div>
    </a>
    <% }) %>
  </div>
  <% } %>
</div>
<%- include('partials/footer') %>
